<div style="padding: 10rem 4rem 6rem; max-width: 1200px; margin: 0 auto;">
  <h1 style="font-family: 'Playfair Display', serif; font-size: 3rem; margin-bottom: 2rem; letter-spacing: 0.1em;">Your Bag</h1>
  
  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post">
      <div style="display: flex; flex-direction: column; gap: 2rem; margin-bottom: 3rem;">
        {% for item in cart.items %}
          <div style="display: grid; grid-template-columns: 120px 1fr auto; gap: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #eee;">
            <a href="{{ item.url }}">
              <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title }}" style="width: 100%; height: 150px; object-fit: cover;">
            </a>
            <div>
              <h3 style="font-family: 'Playfair Display', serif; font-size: 1.3rem; margin-bottom: 0.5rem;">
                <a href="{{ item.url }}" style="color: inherit; text-decoration: none;">{{ item.product.title }}</a>
              </h3>
              {% unless item.variant.title == 'Default Title' %}
                <p style="font-size: 0.85rem; color: #666; margin-bottom: 0.5rem;">{{ item.variant.title }}</p>
              {% endunless %}
              <p style="font-size: 1.1rem; font-weight: 600;">{{ item.price | money }}</p>
              <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem;">
                <button type="button" onclick="this.nextElementSibling.stepDown(); this.closest('form').submit();" style="width:30px; height:30px; border:1px solid #ddd; background:white; cursor:pointer;">−</button>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:50px; text-align:center; padding:0.5rem; border:1px solid #ddd;" onchange="this.closest('form').submit();">
                <button type="button" onclick="this.previousElementSibling.stepUp(); this.closest('form').submit();" style="width:30px; height:30px; border:1px solid #ddd; background:white; cursor:pointer;">+</button>
              </div>
            </div>
            <div style="text-align: right;">
              <p style="font-weight: 600; font-size: 1.1rem;">{{ item.line_price | money }}</p>
              <a href="{{ item.url_to_remove }}" style="font-size: 0.8rem; color: #999; text-decoration: underline; margin-top: 1rem; display: inline-block;">Remove</a>
            </div>
          </div>
        {% endfor %}
      </div>
      
      <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 2rem;">
        <div>
          <a href="{{ routes.all_products_collection_url }}" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--black); text-decoration: none;">← Continue Shopping</a>
        </div>
        <div style="text-align: right; min-width: 300px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 1.3rem; font-family: 'Playfair Display', serif;">
            <span>Subtotal</span>
            <span style="font-weight: 700;">{{ cart.total_price | money }}</span>
          </div>
          <p style="font-size: 0.75rem; color: #888; margin-bottom: 1.5rem;">Shipping & taxes calculated at checkout</p>
          <button type="submit" name="checkout" style="width: 100%; padding: 1.3rem; background: var(--black); color: var(--white); border: none; font-size: 0.9rem; letter-spacing: 0.25em; text-transform: uppercase; cursor: pointer; font-family: 'Inter', sans-serif; font-weight: 500;">
            Proceed to Checkout
          </button>
        </div>
      </div>
    </form>
  {% else %}
    <div style="text-align: center; padding: 4rem 0;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="width: 80px; height: 80px; margin-bottom: 2rem; opacity: 0.3;">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
        <path d="M3 6h18"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <h2 style="font-family: 'Playfair Display', serif; font-size: 1.8rem; margin-bottom: 1rem;">Your bag is empty</h2>
      <p style="color: #666; margin-bottom: 2rem;">Discover our luxurious fragrances</p>
      <a href="{{ routes.all_products_collection_url }}" style="display: inline-block; padding: 1.2rem 3rem; border: 2px solid var(--black); color: var(--black); text-decoration: none; font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase;">
        Shop Now
      </a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart Page",
  "tag": "section",
  "settings": []
}
{% endschema %}
