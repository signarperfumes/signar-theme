<!-- HERO SECTION -->
<section class="hero" id="home">
  {% if section.settings.hero_image != blank %}
    <div class="hero-bg" style="background-image: url('{{ section.settings.hero_image | image_url: width: 1920 }}');"></div>
  {% endif %}
  <div class="hero-content">
    <p class="hero-subtitle">{{ section.settings.hero_subtitle }}</p>
    <h1 class="hero-title">{{ section.settings.hero_title }}</h1>
    <p class="hero-description">{{ section.settings.hero_description }}</p>
    <a href="{{ section.settings.hero_button_link }}" class="hero-cta">{{ section.settings.hero_button_text }}</a>
  </div>
  <div class="scroll-indicator">Scroll</div>
</section>

<!-- COLLECTIONS SECTION -->
<section class="collections" id="collections">
  <div class="section-header reveal">
    <p class="section-subtitle">{{ section.settings.collections_subtitle }}</p>
    <h2 class="section-title">{{ section.settings.collections_title }}</h2>
  </div>
  <div class="collections-grid">
    {% for block in section.blocks %}
      {% if block.type == 'collection' %}
        {% assign collection = collections[block.settings.collection] %}
        {% if collection != blank %}
          <div class="collection-card reveal" {{ block.shopify_attributes }}>
            {% if collection.image %}
              <img src="{{ collection.image | image_url: width: 1200 }}" alt="{{ collection.title }}" class="collection-image">
            {% elsif collection.products.first.featured_image %}
              <img src="{{ collection.products.first.featured_image | image_url: width: 1200 }}" alt="{{ collection.title }}" class="collection-image">
            {% endif %}
            <div class="collection-overlay">
              <h3 class="collection-name">{{ collection.title }}</h3>
              <a href="{{ collection.url }}" class="collection-link">Shop Now</a>
            </div>
          </div>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- FEATURED PRODUCTS -->
<section class="featured-products" id="shop">
  <div class="section-header reveal">
    <p class="section-subtitle">{{ section.settings.products_subtitle }}</p>
    <h2 class="section-title">{{ section.settings.products_title }}</h2>
  </div>
  <div class="products-grid">
    {% for product in section.settings.product_list %}
      <div class="product-card reveal" data-id="{{ product.id }}">
        <a href="{{ product.url }}" style="text-decoration:none; color:inherit;">
          <div class="product-image-wrapper">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="product-image" loading="lazy">
            {% endif %}
            {% if product.available == false %}
              <span class="product-badge">Sold Out</span>
            {% elsif product.compare_at_price > product.price %}
              <span class="product-badge">Sale</span>
            {% endif %}
          </div>
          <div class="product-info">
            <h3 class="product-name">{{ product.title }}</h3>
            <p class="product-category">
              {% for collection in product.collections limit:1 %}
                {{ collection.title }}
              {% endfor %}
            </p>
            <p class="product-price">{{ product.price | money }}</p>
          </div>
        </a>
        {% if product.available %}
          <button class="product-cta" data-add-id="{{ product.id }}">Add to Bag</button>
        {% else %}
          <button class="product-cta" disabled style="opacity:0.5; cursor:not-allowed;">Sold Out</button>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

<!-- TRUST BADGES -->
