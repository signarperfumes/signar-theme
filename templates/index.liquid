    <div class="badge-item reveal">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
      </div>
      <h3 class="badge-title">{{ section.settings.badge1_title }}</h3>
      <p class="badge-description">{{ section.settings.badge1_desc }}</p>
    </div>
    <div class="badge-item reveal">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="3" width="15" height="13"/>
          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </div>
      <h3 class="badge-title">{{ section.settings.badge2_title }}</h3>
      <p class="badge-description">{{ section.settings.badge2_desc }}</p>
    </div>
    <div class="badge-item reveal">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h3 class="badge-title">{{ section.settings.badge3_title }}</h3>
      <p class="badge-description">{{ section.settings.badge3_desc }}</p>
    </div>
    <div class="badge-item reveal">
      <div class="badge-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <h3 class="badge-title">{{ section.settings.badge4_title }}</h3>
      <p class="badge-description">{{ section.settings.badge4_desc }}</p>
    </div>
  </div>
</section>

<!-- FAQ SECTION -->
<section class="faq-section">
  <div class="section-header reveal">
    <p class="section-subtitle">{{ section.settings.faq_subtitle }}</p>
    <h2 class="section-title">{{ section.settings.faq_title }}</h2>
  </div>
  <div class="faq-container">
    {% for block in section.blocks %}
      {% if block.type == 'faq' %}
        <div class="faq-item reveal" {{ block.shopify_attributes }}>
          <div class="faq-question">
            <h3>{{ block.settings.question }}</h3>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- WAVE -->
<div class="wave-container">
  <div class="wave">
    <svg viewBox="0 0 1440 200" preserveAspectRatio="none">
      <path d="M0,100 C240,150 480,50 720,100 C960,150 1200,50 1440,100 L1440,200 L0,200 Z" fill="#000"/>
      <path d="M0,120 C240,170 480,70 720,120 C960,170 1200,70 1440,120 L1440,200 L0,200 Z" fill="#000" opacity="0.5"/>
    </svg>
  </div>
</div>

<!-- NEWSLETTER -->
<section class="newsletter-section">
  <div class="newsletter-content">
    <p class="newsletter-subtitle">{{ section.settings.newsletter_subtitle }}</p>
    <h2 class="newsletter-title">{{ section.settings.newsletter_title }}</h2>
    <p class="newsletter-desc">{{ section.settings.newsletter_desc }}</p>
    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" class="newsletter-input" placeholder="Enter your email address" required>
      <button type="submit" class="newsletter-submit">
        Subscribe
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    {% endform %}
    <p class="newsletter-note">By subscribing, you agree to our Privacy Policy. Unsubscribe anytime.</p>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer" id="contact">
  <div class="footer-content">
    <div class="footer-brand">
      <div class="footer-logo">{{ shop.name | upcase }}</div>
      <p class="footer-description">{{ section.settings.footer_description }}</p>
      <div class="footer-social">
        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_twitter != blank %}
          <a href="{{ section.settings.social_twitter }}" aria-label="Twitter" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>
    <div class="footer-column">
      <h4>Shop</h4>
      <ul class="footer-links">
        {% for link in linklists.footer.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div class="footer-column">
      <h4>Company</h4>
      <ul class="footer-links">
        {% for link in linklists.footer-secondary.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div class="footer-column">
      <h4>Policies</h4>
      <ul class="footer-links">
        {% if shop.privacy_policy %}
          <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
        {% endif %}
        {% if shop.terms_of_service %}
          <li><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>
        {% endif %}
        {% if shop.shipping_policy %}
          <li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
        {% endif %}
        {% if shop.refund_policy %}
          <li><a href="{{ shop.refund_policy.url }}">Return Policy</a></li>
        {% endif %}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. Crafted with elegance in Pakistan.</p>
  </div>
</footer>

<!-- ADD TO CART SCRIPT -->
<script>
  document.querySelectorAll('[data-add-id]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const productId = parseInt(btn.dataset.addId);
      
      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: productId,
            quantity: 1
          })
        });
        
        if (response.ok) {
          btn.textContent = 'Added ✓';
          btn.classList.add('added');
          showToast('Added to bag');
          
          // Update cart count in navbar
          const cartCountEl = document.querySelector('.cart-count');
          if (cartCountEl) {
            const currentCount = parseInt(cartCountEl.textContent) || 0;
            cartCountEl.textContent = currentCount + 1;
            cartCountEl.style.display = 'flex';
            cartCountEl.classList.remove('bump');
            void cartCountEl.offsetWidth;
            cartCountEl.classList.add('bump');
          }
          
          setTimeout(() => {
            btn.textContent = 'Add to Bag';
            btn.classList.remove('added');
          }, 1500);
        }
      } catch (err) {
        showToast('Error adding to cart');
      }
    });
  });
</script>

